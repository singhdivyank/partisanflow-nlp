{
  "raw_parquet": {
    "min_row_count": 10000,
    "required_columns": ["series", "issue", "text", "date"],
    "not_null_columns": ["series", "issue", "date"],
    "text_length": {
      "min_chars": 10,
      "max_chars": 500000
    }
  },

  "metadata": {
    "min_row_count": 100,
    "required_columns": ["series", "contents"],
    "not_null_columns": ["series"],
    "expected_labels": ["democratic", "republican", "independent"]
  },

  "processed": {
    "min_row_count": 5000,
    "required_columns": ["series", "issue", "year", "paragraph_id", "text"],
    "not_null_columns": ["series", "issue", "year"],
    "max_text_length": 100000,
    "min_paragraph_words": 2,
    "label_distribution": {
      "warn_imbalance_ratio": 4.0
    }
  },

  "feature_store": {
    "min_row_count": 5000,
    "required_columns": ["series", "issue", "year", "paragraph_id", "features"],
    "not_null_columns": ["series", "issue", "year", "paragraph_id", "features"],
    "feature_vector": {
      "min_nonzero_elements": 1
    }
  },

  "predictions": {
    "min_row_count": 100,
    "required_columns": ["series", "issue", "year", "pred_label", "prob_democrat", "prob_republican"],
    "not_null_columns": ["series", "issue", "year", "pred_label"],
    "valid_labels": [0.0, 1.0, 2.0, 3.0],
    "probability_range": {
      "min": 0.0,
      "max": 1.0
    }
  },

  "drift_metrics": {
    "required_columns": ["year", "ref_year", "model_name", "metric_name", "metric_value"],
    "not_null_columns": ["year", "ref_year", "model_name", "metric_name", "metric_value"],
    "psi_thresholds": {
      "warning":  0.1,
      "critical": 0.2
    }
  }
}